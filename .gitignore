# This .gitignore is for Unity projects
# It excludes build output, Library, Temp, etc.

# Build output
Build/
Builds/

# Autogenerated by Unity
Library/
Temp/
obj/
*.csproj
*.sln
*.userprefs
*.unityproj
*.pidb
*.booproj

# User-specific settings
UserSettings/

# OS files
.DS_Store
Thumbs.db
Desktop.ini

# Rider / IDE
.idea/
*.sln.DotSettings.user
.vscode/

# Logs
*.log
Logs/

# Crash reports
CrashReport/

# Asset meta files should be tracked
# But if you want to ignore specific patterns, add below

# Memory dumps
*.memoryleak
memreport*
